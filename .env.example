# Telegram bot integration
# Copy this file to .env and fill in your values.

TELEGRAM_TOKEN=your_bot_token_here
# One chat ID, or multiple separated by commas: 123456789,987654321
TELEGRAM_CHAT_ID=your_chat_id_here

# Audio (notification chime + game sounds). Optional.
# ALSA device for the USB speaker. Find it with: aplay -l
# Example: plughw:CARD=USB,DEV=0
AUDIO_DEVICE=
# Path to a custom WAV to play on incoming Telegram messages.
# Leave empty to use the built-in two-tone chime.
TELEGRAM_SOUND=
# Set to 1 to disable all sound output.
NO_AUDIO=
